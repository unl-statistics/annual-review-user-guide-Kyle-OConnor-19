
@article{yanConsequencesAskingSensitive2020,
	title = {Consequences of Asking Sensitive Questions in Surveys},
	volume = {8},
	issn = {2326-8298, 2326-831X},
	url = {https://www.annualreviews.org/content/journals/10.1146/annurev-statistics-040720-033353;jsessionid=nYoF2JSjRT7sSI6TQadTfeeejhnNHWbCMZwhgfFi.annurevlive-10-241-10-92},
	doi = {10.1146/annurev-statistics-040720-033353},
	abstract = {I review selected articles from the survey methodology literature on the consequences of asking sensitive questions in censuses and surveys, using a total survey error ({TSE}) framework. I start with definitions of sensitive questions and move to examination of the impact of including sensitive questions on various sources of survey error—specifically, survey respondents’ willingness to participate in a survey (unit nonresponse), their willingness to respond to next rounds of interviews (wave nonresponse), their likelihood to provide an answer to sensitive questions after agreeing to participate in the survey (item nonresponse), and the accuracy of respondents’ answers to sensitive questions (measurement error). I also review the simultaneous impact of sensitive questions on multiple sources of error in survey estimates and discuss strategies to mitigate the impact of asking sensitive questions on measurement errors. I conclude with a summary and suggestions for future research.},
	pages = {109--127},
	issue = {Volume 8, 2021},
	journaltitle = {Annual Review of Statistics and Its Application},
	publisher = {Annual Reviews},
	author = {Yan, Ting},
	urldate = {2026-01-26},
	date = {2020-11-13},
	langid = {english},
	file = {Full Text:C\:\\Users\\kylea\\Zotero\\storage\\YENJXVFT\\Yan - 2021 - Consequences of Asking Sensitive Questions in Surveys.pdf:application/pdf;Snapshot:C\:\\Users\\kylea\\Zotero\\storage\\QHW5R2EZ\\annurev-statistics-040720-033353\;jsessionid=nYoF2JSjRT7sSI6TQadTfeeejhnNHWbCMZwhgfFi.html:text/html},
}

@book{tourangeauPsychologySurveyResponse2000,
	title = {The Psychology of Survey Response},
	isbn = {978-0-521-57629-1},
	url = {https://books.google.com/books?id=bjVYdyXXT3oC&lpg=PR11&ots=Z01pNG4FyY&lr&pg=PP1#v=onepage&q&f=false},
	abstract = {This valuable book examines the complex psychological processes involved in answering different types of survey questions. Drawing on both classic and modern research from cognitive psychology, social psychology, and survey methodology, the authors examine how survey responses are formulated and they demonstrate how seemingly unimportant features of the survey can affect the answers obtained. The book provides a comprehensive review of the sources of response errors in surveys, and it offers a coherent theory of the relation between the underlying views of the public and the results of public opinion polls. Topics include the comprehension of survey questions, the recall of relevant facts and beliefs, estimation and inferential processes people use to answer survey questions, the sources of the apparent instability of public opinion, the difficulties in getting responses into the required format, and the distortions introduced into surveys by deliberate misreporting.},
	pages = {1-62},
	publisher = {Cambridge University Press},
	author = {Tourangeau, Roger and Rips, Lance J. and Rasinski, Kenneth},
	date = {2000-03-13},
	langid = {english},
	note = {Google-Books-{ID}: {bjVYdyXXT}3oC},
	keywords = {Psychology / Personality, Psychology / Reference, Psychology / Research \& Methodology, Psychology / Social Psychology, Social Science / Statistics},
}

@article{ongImpactAnonymityResponses2006,
	title = {The Impact of Anonymity on Responses to Sensitive Questions},
	volume = {30},
	issn = {1559-1816},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/j.1559-1816.2000.tb02462.x},
	doi = {10.1111/j.1559-1816.2000.tb02462.x},
	abstract = {To estimate frequencies of behaviors not carried out in public view, researchers generally must rely on self-report data. We explored 2 factors expected to influence the decision to reveal: (a) privacy (anonymity vs. confidentiality) and (b) normalization (providing information so that a behavior is reputedly commonplace or rare). We administered a questionnaire to I55 undergraduates. For 79 respondents, we had corroborative information regarding a negative behavior: cheating. The privacy variable had an enormous impact; of those who had cheated, 25\% acknowledged having done so under confidentiality, but 74\% admitted the behavior under anonymity. Normalization had no effect. There were also dramatic differences between anonymity and confidentiality on some of our other questions, for which we did not have validation.},
	pages = {1691--1708},
	number = {8},
	journaltitle = {Journal of Applied Social Psychology},
	author = {Ong, Anthony D. and Weiss, David J.},
	urldate = {2026-01-26},
	date = {2006-07-31},
	langid = {english},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/j.1559-1816.2000.tb02462.x},
	file = {Full Text PDF:C\:\\Users\\kylea\\Zotero\\storage\\FE2QWUMS\\Ong and Weiss - 2000 - The Impact of Anonymity on Responses to Sensitive Questions.pdf:application/pdf;Snapshot:C\:\\Users\\kylea\\Zotero\\storage\\TCNIU6DJ\\j.1559-1816.2000.tb02462.html:text/html},
}

